def __init__(self, main_window, doc):
    self.main_window = main_window
    self.print_pdf_with_settings(doc)

def print_pdf_with_settings(self, doc):
    total_pages = len(doc)
    if total_pages == 0:
        QMessageBox.warning(self.main_window, "Пустой PDF", "Файл не содержит страниц.")
        return

    # Создаём принтер
    printer = QPrinter(QPrinter.HighResolution)
    printer.setFromTo(1, total_pages)

    # Настройки печати
    print_dialog = QPrintDialog(printer, self.main_window)
    print_dialog.setWindowTitle("Печать документа")

    # Включаем нужные опции
    print_dialog.setOption(QPrintDialog.PrintPageRange, True)
    print_dialog.setOption(QPrintDialog.PrintCollateCopies, True)
    print_dialog.setOption(QPrintDialog.PrintShowPageSize, True)
    print_dialog.setOption(QPrintDialog.PrintToFile, True)
    if print_dialog.exec() != QPrintDialog.Accepted:
        return

    # Получаем настройки
    mode = printer.printRange()
    printer_name = printer.printerName()
    copies = printer.copyCount()
    collate = printer.collateCopies()

    # Получаем список страниц
    pages_to_print = self._extract_pages_from_printer(printer, total_pages, mode)
    if not pages_to_print:
        QMessageBox.information(self.main_window, "Нет страниц", "Диапазон страниц пуст.")
        return

    # --- KEY FIX ---
    # Use paintRect (the actual printable area) not fullRect.
    # paintRect is in device pixels and already excludes hardware margins.
    # Do NOT divide by printer.resolution() — paintRect is already in pixels.
    layout = printer.pageLayout()

    # paintRectPixels gives the printable rect in device pixels
    paint_rect_px = printer.pageLayout().paintRectPixels(printer.resolution())
    paper_w_px = paint_rect_px.width()
    paper_h_px = paint_rect_px.height()

    # Render at the printer's native DPI for best quality (cap at 300 to
    # avoid huge memory use on 1200-dpi printers)
    render_dpi = min(printer.resolution(), 300)

    # 5. Печать
    painter = QPainter(printer)
    try:
        for idx, page_num in enumerate(pages_to_print):
            page = doc.load_page(page_num)
            rect = page.rect
            is_landscape = rect.width > rect.height

            # Рендерим с нужным DPI
            scale = render_dpi / self.points_per_inch
            mat = fitz.Matrix(scale, scale)
            pix = page.get_pixmap(matrix=mat)
            qimg = QImage.fromData(pix.tobytes("png"), "png")
            if qimg.isNull():
                raise RuntimeError(f"Не удалось создать QImage для страницы {page_num + 1}")

            # Поворот для альбомных страниц
            if is_landscape:
                transform = QTransform().rotate(90)
                qimg = qimg.transformed(transform)

            # Размеры изображения после поворота
            img_w = qimg.width()
            img_h = qimg.height()

            # Масштабируем под лист (без переполнения), сохраняя пропорции
            if img_w and img_h:
                scale_factor = min(paper_w_px / img_w, paper_h_px / img_h)
            else:
                scale_factor = 1.0

            scale_w = img_w * scale_factor
            scale_h = img_h * scale_factor

            # Центрируем внутри printable area.
            # Origin (0, 0) of the painter IS already the top-left of the
            # paintable area — no need to add hardware margin offsets.
            target_x = (paper_w_px - scale_w) / 2
            target_y = (paper_h_px - scale_h) / 2
            target_rect = QRectF(target_x, target_y, scale_w, scale_h)

            painter.drawImage(target_rect, qimg)

            if idx < len(pages_to_print) - 1:
                printer.newPage()

    except Exception as e:
        painter.end()
        QMessageBox.critical(self.main_window, "Ошибка печати", f"Произошла ошибка:\n{e}")
        return

    painter.end()

    msg = (
        f"Печать завершена!\n"
        f"Принтер: {printer_name or 'По умолчанию'}\n"
        f"Страниц: {len(pages_to_print)} из {total_pages}\n"
        f"Копий: {copies}, Коллация: {'Да' if collate else 'Нет'}"
    )
    QMessageBox.information(self.main_window, "Успех", msg)

def _extract_pages_from_printer(self, printer, total_pages, mode):
    """
    Извлекает список страниц из QPrinter в зависимости от printRange().
    """
    pages = []

    if mode == QPrinter.PrintRange.PageRange:
        from_page = printer.fromPage()
        to_page = printer.toPage()
        if from_page <= 0:
            from_page = 1
        if to_page > total_pages:
            to_page = total_pages
        pages = list(range(from_page - 1, to_page))

    elif mode == QPrinter.PrintRange.AllPages:
        pages = list(range(total_pages))

    elif mode == QPrinter.PrintRange.CurrentPage:
        # Qt6 нет CurrentPage — оставим как fallback
        pages = [0]

    # Уникальные, отсортированные, валидные
    return sorted({p for p in pages if 0 <= p < total_pages})

def render_page_with_correct_scale(self, page, target_dpi):
    scale = target_dpi / 72.0   # 1 point = 1/72 inch → *scale = пиксели
    mat = fitz.Matrix(scale, scale)
    pix = page.get_pixmap(matrix=mat)
    return pix
