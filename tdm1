class LayerStrip(QFrame):
    def __init__(self,layer,parent=None):
        super().__init__(parent); self.layer=layer; self.setObjectName("card")
        row=QHBoxLayout(self); row.setContentsMargins(14,9,14,9); row.setSpacing(12)
        r,g,b=[int(c*255) for c in layer.color]
        dot=QLabel("●"); dot.setStyleSheet(f"color:rgb({r},{g},{b});font-size:13px;"); dot.setFixedWidth(14)
        row.addWidget(dot)
        nm=QLabel(layer.name.upper()); nm.setObjectName("layerName"); nm.setFixedWidth(90)
        row.addWidget(nm)
        sl=QSlider(Qt.Horizontal); sl.setRange(0,100); sl.setValue(int(layer.volume*100))
        sl.valueChanged.connect(lambda v:layer.set_volume(v/100)); row.addWidget(sl,stretch=1)
        self.btn=QPushButton("◎"); self.btn.setObjectName("toggleBtn"); self.btn.setProperty("on",False); self.btn.setCheckable(True)
        self.btn.clicked.connect(self._tog); row.addWidget(self.btn)
    def _tog(self,checked):
        self.layer.enable(checked); self.btn.setProperty("on",checked)
        self.btn.setText("◉" if checked else "◎")
        self.btn.style().unpolish(self.btn); self.btn.style().polish(self.btn)

class Orb(QWidget):
    def __init__(self,engine,parent=None):
        super().__init__(parent); self.engine=engine; self._ph=0.0; self.setFixedSize(150,150)
        t=QTimer(self); t.timeout.connect(self._tick); t.start(40)
    def _tick(self): self._ph+=0.018; self.update()
    def paintEvent(self,event):
        p=QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        cx,cy=self.width()/2,self.height()/2; r=48
        active=[l for l in self.engine.layers if l.enabled]
        if active:
            cr=sum(l.color[0] for l in active)/len(active)
            cg=sum(l.color[1] for l in active)/len(active)
            cb=sum(l.color[2] for l in active)/len(active)
        else: cr,cg,cb=0.28,0.38,0.58
        pulse=math.sin(self._ph)*0.5+0.5
        for i in range(4,0,-1):
            gr=r*(1.0+i*0.22+pulse*0.08); a=max(0,0.055-i*0.01)
            p.setBrush(QBrush(QColor.fromRgbF(cr,cg,cb,a))); p.setPen(Qt.NoPen)
            p.drawEllipse(int(cx-gr),int(cy-gr),int(gr*2),int(gr*2))
        rc=r*(0.88+pulse*0.10)
        g=QRadialGradient(cx,cy,rc)
        g.setColorAt(0.0,QColor.fromRgbF(min(1,cr+0.3),min(1,cg+0.25),min(1,cb+0.2),0.95))
        g.setColorAt(0.6,QColor.fromRgbF(cr,cg,cb,0.75))
        g.setColorAt(1.0,QColor.fromRgbF(cr*0.6,cg*0.6,cb*0.6,0.0))
        p.setBrush(QBrush(g)); p.drawEllipse(int(cx-rc),int(cy-rc),int(rc*2),int(rc*2))
        rs=r*0.25; sx,sy=cx-r*0.16,cy-r*0.16
        sg=QRadialGradient(sx,sy,rs); sg.setColorAt(0,QColor.fromRgbF(1,1,1,0.5)); sg.setColorAt(1,QColor.fromRgbF(1,1,1,0))
        p.setBrush(QBrush(sg)); p.drawEllipse(int(sx-rs),int(sy-rs),int(rs*2),int(rs*2)); p.end()

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.engine=AudioEngine(); self.playing=False
        self.setWindowTitle("ambient"); self.setFixedWidth(420); self.setStyleSheet(STYLE)
        ico=os.path.join(os.path.dirname(os.path.abspath(__file__)),"ambient.ico")
        if os.path.exists(ico): self.setWindowIcon(QIcon(ico))

        root=QWidget(); root.setObjectName("root"); self.setCentralWidget(root)
        main=QVBoxLayout(root); main.setContentsMargins(24,26,24,24); main.setSpacing(0)

        # Header
        top=QHBoxLayout(); top.setSpacing(0)
        left=QVBoxLayout(); left.setSpacing(4)
        t=QLabel("A M B I E N T"); t.setObjectName("title"); left.addWidget(t)
        s=QLabel("GENERATIVE SOUNDSCAPE"); s.setObjectName("secLbl"); left.addWidget(s)
        left.addSpacing(12)
        self.play_btn=QPushButton("▶"); self.play_btn.setObjectName("playBtn")
        self.play_btn.clicked.connect(self.toggle_play); left.addWidget(self.play_btn)
        left.addStretch()
        top.addLayout(left); top.addStretch()
        self.orb=Orb(self.engine); top.addWidget(self.orb,alignment=Qt.AlignTop)
        main.addLayout(top); main.addSpacing(18)

        div=QFrame(); div.setObjectName("div"); main.addWidget(div); main.addSpacing(14)

        lbl=QLabel("LAYERS"); lbl.setObjectName("secLbl"); main.addWidget(lbl); main.addSpacing(8)

        for layer in self.engine.layers:
            main.addWidget(LayerStrip(layer)); main.addSpacing(5)

        main.addSpacing(12)
        div2=QFrame(); div2.setObjectName("div"); main.addWidget(div2); main.addSpacing(14)
        lbl2=QLabel("MASTER"); lbl2.setObjectName("secLbl"); main.addWidget(lbl2); main.addSpacing(10)

        def slider_row(label,init,cb):
            row=QHBoxLayout(); row.setSpacing(12)
            l=QLabel(label); l.setObjectName("secLbl")
            l.setStyleSheet("font-size:10px;letter-spacing:2px;color:rgba(130,150,190,0.5);")
            l.setFixedWidth(68); row.addWidget(l)
            sl=QSlider(Qt.Horizontal); sl.setRange(0,100); sl.setValue(init)
            sl.valueChanged.connect(cb); row.addWidget(sl); return row

        main.addLayout(slider_row("VOLUME",50,lambda v:self.engine.set_master(v/100)))
        main.addSpacing(10)
        main.addLayout(slider_row("REVERB",30,lambda v:self.engine.set_reverb(v/100*0.55)))
        main.addStretch()

    def toggle_play(self):
        if self.playing: self.engine.stop(); self.play_btn.setText("▶")
        else: self.engine.start(); self.play_btn.setText("■")
        self.playing=not self.playing

    def closeEvent(self,event):
        self.engine.stop(); super().closeEvent(event)

