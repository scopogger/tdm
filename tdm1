class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.engine   = AudioEngine()
        self.playing  = False
        self.cur_mood = "Focus"

        self.setWindowTitle("ambient")
        self.setFixedSize(380, 580)
        self.setStyleSheet(STYLE)

        root = QWidget()
        root.setObjectName("root")
        self.setCentralWidget(root)

        lay = QVBoxLayout(root)
        lay.setContentsMargins(30, 36, 30, 36)
        lay.setSpacing(0)

        # ── Title ──────────────────────────────
        title = QLabel("A M B I E N T")
        title.setObjectName("title")
        title.setAlignment(Qt.AlignCenter)
        lay.addWidget(title)

        lay.addSpacing(4)
        self.desc_label = QLabel(AudioEngine.MOODS["Focus"]["desc"])
        self.desc_label.setObjectName("desc")
        self.desc_label.setAlignment(Qt.AlignCenter)
        lay.addWidget(self.desc_label)

        lay.addSpacing(28)

        # ── Visualizer ─────────────────────────
        self.viz = VisualizerWidget()
        lay.addWidget(self.viz, alignment=Qt.AlignCenter)

        lay.addSpacing(28)

        # ── Mood buttons ───────────────────────
        mood_row = QHBoxLayout()
        mood_row.setSpacing(10)
        self.mood_btns = {}
        for mood in ["Focus", "Dreamy", "Rain"]:
            btn = QPushButton(mood)
            btn.setObjectName("moodBtn")
            btn.setProperty("active", mood == self.cur_mood)
            btn.clicked.connect(lambda _, m=mood: self.set_mood(m))
            mood_row.addWidget(btn)
            self.mood_btns[mood] = btn
        lay.addLayout(mood_row)

        lay.addSpacing(28)

        # ── Divider ────────────────────────────
        div = QFrame()
        div.setObjectName("divider")
        lay.addWidget(div)

        lay.addSpacing(22)

        # ── Volume slider ──────────────────────
        vol_lbl = QLabel("VOLUME")
        vol_lbl.setObjectName("sliderLabel")
        lay.addWidget(vol_lbl)
        lay.addSpacing(8)

        self.vol_slider = QSlider(Qt.Horizontal)
        self.vol_slider.setRange(0, 100)
        self.vol_slider.setValue(35)
        self.vol_slider.valueChanged.connect(
            lambda v: self.engine.set_volume(v / 100))
        lay.addWidget(self.vol_slider)

        lay.addSpacing(18)

        # ── Intensity slider ───────────────────
        int_lbl = QLabel("INTENSITY")
        int_lbl.setObjectName("sliderLabel")
        lay.addWidget(int_lbl)
        lay.addSpacing(8)

        self.int_slider = QSlider(Qt.Horizontal)
        self.int_slider.setRange(0, 100)
        self.int_slider.setValue(50)
        self.int_slider.valueChanged.connect(
            lambda v: self.engine.set_intensity(v / 100))
        lay.addWidget(self.int_slider)

        lay.addSpacing(28)

        # ── Play button ────────────────────────
        self.play_btn = QPushButton("▶")
        self.play_btn.setObjectName("playBtn")
        self.play_btn.clicked.connect(self.toggle_play)
        lay.addWidget(self.play_btn, alignment=Qt.AlignCenter)

        lay.addStretch()

    def set_mood(self, mood):
        self.cur_mood = mood
        self.engine.set_mood(mood)
        self.viz.set_mood(mood)
        self.desc_label.setText(AudioEngine.MOODS[mood]["desc"])

        for name, btn in self.mood_btns.items():
            btn.setProperty("active", name == mood)
            btn.style().unpolish(btn)
            btn.style().polish(btn)

    def toggle_play(self):
        if self.playing:
            self.engine.stop()
            self.play_btn.setText("▶")
            self.viz.set_playing(False)
        else:
            self.engine.start()
            self.play_btn.setText("■")
            self.viz.set_playing(True)
        self.playing = not self.playing

    def closeEvent(self, event):
        self.engine.stop()
        super().closeEvent(event)


