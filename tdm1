import sys
import os
import json
import base64
import csv
import re

CHUNK_RE = re.compile(r’^(\d+)/(\d+):(.+)$’)

OUT_DIR = ‘received’

def parse_chunk(text: str):
“”“Parse ‘INDEX/TOTAL:payload’ → (index, total, payload) or None.”””
text = text.strip()
m = CHUNK_RE.match(text)
if not m:
return None
return int(m.group(1)), int(m.group(2)), m.group(3)

def collect_from_file(path: str) -> list[str]:
lines = []
if path.lower().endswith(’.csv’):
with open(path, newline=’’, encoding=‘utf-8’) as f:
for row in csv.reader(f):
for cell in row:
if CHUNK_RE.match(cell.strip()):
lines.append(cell.strip())
else:
with open(path, encoding=‘utf-8’) as f:
for line in f:
line = line.strip()
if line:
lines.append(line)
return lines

def collect_interactive() -> list[str]:
print(“Paste each scanned QR chunk and press Enter.”)
print(“Type  done  (or leave blank and press Enter twice) when finished.\n”)
lines = []
blank_count = 0
while True:
try:
line = input(f”  Chunk [{len(lines)+1}]: “).strip()
except (EOFError, KeyboardInterrupt):
break
if line.lower() == ‘done’:
break
if line == ‘’:
blank_count += 1
if blank_count >= 2:
break
continue
blank_count = 0
lines.append(line)
return lines

