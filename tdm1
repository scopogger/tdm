def export_pages(self):
    """Export selected pages as images or a PDF document"""
    pv = getattr(self.ui, 'pdfView', None)
    if not pv or not hasattr(pv, 'document') or pv.document is None:
        QMessageBox.warning(self.main_window, "Нет документа", "Пожалуйста, сначала откройте PDF файл.")
        return

    cur_doc = pv.document.current_doc
    total_pages = cur_doc.page_count
    if total_pages <= 0:
        QMessageBox.warning(self.main_window, "Ошибка", "Не удалось определить количество страниц.")
        return

    dialog = PagesRangeDialog(self.main_window, "EXPORT")
    if dialog.exec() != QDialog.Accepted:
        return

    try:
        pages_to_export = dialog.get_page_ranges()
        if not pages_to_export:
            return
    except ValueError as e:
        QMessageBox.warning(self.main_window, "Ошибка ввода", f"Некорректные данные: {e}")
        return

    # --- Ask format: PDF or image ---
    format_choice, ok = QInputDialog.getItem(
        self.main_window,
        "Формат экспорта",
        "Выберите формат экспорта:",
        ["PDF", "JPEG", "PNG", "BMP"],
        0,
        False
    )
    if not ok:
        return

    # ── PDF export branch ──────────────────────────────────────────
    if format_choice == "PDF":
        last_dir = settings_manager.get_last_directory()
        doc_basename = os.path.splitext(os.path.basename(
            getattr(self.main_window, 'current_document_path', '') or 'document'
        ))[0]
        default_name = f"{doc_basename}_pages_export.pdf"

        file_path, _ = QFileDialog.getSaveFileName(
            self.main_window,
            "Сохранить страницы как PDF",
            os.path.join(last_dir, default_name),
            "PDF Files (*.pdf)"
        )
        if not file_path:
            return
        if not file_path.lower().endswith('.pdf'):
            file_path += '.pdf'

        settings_manager.save_last_directory(os.path.dirname(file_path))

        try:
            new_doc = fitz.open()
            for page_num in pages_to_export:
                new_doc.insert_pdf(cur_doc, from_page=page_num, to_page=page_num)
            new_doc.save(file_path)
            new_doc.close()

            QMessageBox.information(
                self.main_window,
                "Успешно",
                f"Экспортировано {len(pages_to_export)} стр. в файл:\n{os.path.basename(file_path)}"
            )
        except Exception as e:
            QMessageBox.critical(
                self.main_window,
                "Ошибка",
                f"Не удалось сохранить PDF:\n{str(e)}"
            )
        return

    # ── Image export branch ────────────────────────────────────────
    zoom_levels = {
        "Среднее (72 DPI)": 1.0,
        "Хорошее (150 DPI)": 2.0,
        "Высокое (300 DPI)": 4.0,
        "Очень высокое (600 DPI)": 8.0
    }

    quality, ok = QInputDialog.getItem(
        self.main_window,
        "Качество изображения",
        "Выберите качество изображения:",
        list(zoom_levels.keys()),
        1,
        False
    )
    if not ok:
        return

    zoom = zoom_levels[quality]

    last_dir = settings_manager.get_last_directory()
    doc_basename = os.path.splitext(os.path.basename(
        getattr(self.main_window, 'current_document_path', '') or 'document'
    ))[0]

    if len(pages_to_export) > 1:
        output_dir = QFileDialog.getExistingDirectory(
            self.main_window,
            "Выберите папку для сохранения изображений",
            last_dir
        )
        if not output_dir:
            return
        settings_manager.save_last_directory(output_dir)
        format_type = format_choice
        format_ext = format_choice.lower()
        quality_param = 95 if format_choice == "JPEG" else 100
    else:
        filter_map = {
            "JPEG": "Изображения JPEG (*.jpg *.jpeg)",
            "PNG":  "Изображения PNG (*.png)",
            "BMP":  "Изображения BMP (*.bmp)",
        }
        default_name = f"{doc_basename}_p{pages_to_export[0] + 1}_{quality.replace(' ', '_').lower()}.{format_choice.lower()}"
        file_path, _ = QFileDialog.getSaveFileName(
            self.main_window,
            f"Сохранить страницу как изображение ({quality})",
            os.path.join(last_dir, default_name),
            filter_map[format_choice]
        )
        if not file_path:
            return
        settings_manager.save_last_directory(os.path.dirname(file_path))
        format_type = format_choice
        format_ext = format_choice.lower()
        quality_param = 95 if format_choice == "JPEG" else 100

    try:
        progress = QProgressDialog(
            f"Экспорт {len(pages_to_export)} страниц...",
            "Отмена",
            0,
            len(pages_to_export),
            self.main_window
        )
        progress.setWindowModality(Qt.WindowModal)
        progress.show()
        QApplication.processEvents()

        successful = 0
        failed = []

        for idx, page_num in enumerate(pages_to_export):
            progress.setValue(idx)
            QApplication.processEvents()
            if progress.wasCanceled():
                break

            try:
                page = pv.document.get_page(page_num)
                rotation = pv.page_rotations.get(page_num, 0)
                if rotation != 0:
                    page.set_rotation(rotation)

                matrix = fitz.Matrix(zoom, zoom)
                pix = page.get_pixmap(matrix=matrix, alpha=False, colorspace=fitz.csRGB)
                img_data = pix.tobytes("ppm")
                image = QImage()
                image.loadFromData(img_data)

                if image.isNull():
                    raise Exception("Не удалось преобразовать страницу в изображение.")

                if len(pages_to_export) > 1:
                    filename = f"{doc_basename}_p{page_num + 1}.{format_ext}"
                    path = os.path.join(output_dir, filename)
                else:
                    path = file_path

                success = image.save(path, format_type, quality_param)
                if success:
                    successful += 1
                else:
                    failed.append(page_num + 1)

            except Exception as e:
                failed.append(page_num + 1)

        progress.close()

        if failed:
            QMessageBox.information(
                self.main_window,
                "Экспорт завершён с ошибками",
                f"Успешно сохранено: {successful}\nОшибки на страницах: {', '.join(map(str, failed))}"
            )
        elif len(pages_to_export) > 1:
            QMessageBox.information(
                self.main_window,
                "Успешно",
                f"Все {successful} страниц сохранены в папке:\n{output_dir}"
            )
        else:
            QMessageBox.information(
                self.main_window,
                "Успешно",
                f"Страница {pages_to_export[0] + 1} сохранена в качестве '{quality}'\n"
                f"Файл: {os.path.basename(file_path)}\n"
                f"Размер: {image.width()} x {image.height()} пикселей"
            )

    except Exception as e:
        try:
            progress.close()
        except:
            pass
        QMessageBox.critical(
            self.main_window,
            "Ошибка",
            f"Не удалось сохранить страницы как изображения:\n{str(e)}"
        )
