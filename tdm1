# ── Reverb ────────────────────────────────────────────────────────────────────

class SimpleReverb:
    COMB_DELAYS    = [1557, 1617, 1491, 1422]
    ALLPASS_DELAYS = [225, 556]
    def __init__(self):
        self._wet  = 0.3
        self._combs   = [np.zeros(d) for d in self.COMB_DELAYS]
        self._comb_i  = [0]*4
        self._ap      = [np.zeros(d) for d in self.ALLPASS_DELAYS]
        self._ap_i    = [0,0]
    def set_wet(self, w): self._wet = float(w)
    def process(self, signal):
        if self._wet < 0.005: return signal
        out = np.zeros_like(signal)
        for i,(buf,dl) in enumerate(zip(self._combs,self.COMB_DELAYS)):
            idx=self._comb_i[i]; decay=0.84
            for n,s in enumerate(signal):
                d=buf[idx]; buf[idx]=s+d*decay; out[n]+=d; idx=(idx+1)%dl
            self._comb_i[i]=idx
        out /= len(self.COMB_DELAYS)
        for i,(buf,dl) in enumerate(zip(self._ap,self.ALLPASS_DELAYS)):
            idx=self._ap_i[i]; g=0.5; res=np.zeros_like(out)
            for n,s in enumerate(out):
                d=buf[idx]; buf[idx]=s+d*g; res[n]=d-g*buf[idx]; idx=(idx+1)%dl
            self._ap_i[i]=idx; out=res
        return signal*(1-self._wet)+out*self._wet

# ── Layer base ────────────────────────────────────────────────────────────────

class Layer:
    def __init__(self,name,color):
        self.name=name; self.color=color
        self.enabled=False; self.volume=0.5
        self._t=0; self._fade=0.0
    def enable(self,v): self.enabled=v
    def set_volume(self,v): self.volume=max(0.0,min(1.0,v))
    def generate(self,frames): raise NotImplementedError
    def tick(self,frames):
        target=1.0 if self.enabled else 0.0
        step=frames/(SR*1.2)
        self._fade=np.clip(self._fade+(step if target else -step),0,1)
        if self._fade<0.001: self._t+=frames; return np.zeros(frames)
        sig=self.generate(frames)*self.volume*self._fade
        self._t+=frames; return sig

# ── Layers ────────────────────────────────────────────────────────────────────

class DroneLayer(Layer):
    def __init__(self):
        super().__init__("Deep Drone",(0.4,0.6,1.0)); self.volume=0.7
    def generate(self,frames):
        t=self._t+np.arange(frames,dtype=np.float64)
        f1,f2=55.0,55.14
        lfo=1.0+0.04*np.sin(TWO_PI*0.07*t/SR)
        sig=0.6*np.sin(TWO_PI*f1*t/SR)+0.6*np.sin(TWO_PI*f2*t/SR)
        sig+=0.25*np.sin(TWO_PI*f1*2*t/SR)
        return sig*lfo/1.45

class ShimmerLayer(Layer):
    def __init__(self):
        super().__init__("Shimmer",(0.75,0.55,1.0)); self.volume=0.45
    def generate(self,frames):
        t=self._t+np.arange(frames,dtype=np.float64)
        base=293.66; sig=np.zeros(frames)
        ratios=[1.0,1.5,2.0,3.0,4.0]; amps=[1.0,0.55,0.35,0.18,0.08]
        for r,a in zip(ratios,amps):
            lfo=1.0+0.07*np.sin(TWO_PI*(0.11+r*0.04)*t/SR)
            sig+=a*lfo*np.sin(TWO_PI*base*r*t/SR)
        sh=np.sin(TWO_PI*0.23*t/SR)*0.5+0.5
        sig+=0.12*sh*np.sin(TWO_PI*base*8*t/SR)
        return sig/(sum(amps)+0.12)

class RainLayer(Layer):
    def __init__(self):
        super().__init__("Rain",(0.4,0.8,0.7))
        self._pb=np.zeros(7); self._dtimer=0
        self._dbuf=np.zeros(512); self._dpos=512; self.volume=0.55
    def _pink(self,w):
        b=self._pb; out=np.empty_like(w)
        for i,x in enumerate(w):
            b[0]=0.99886*b[0]+x*0.0555179; b[1]=0.99332*b[1]+x*0.0750759
            b[2]=0.96900*b[2]+x*0.1538520; b[3]=0.86650*b[3]+x*0.3104856
            b[4]=0.55000*b[4]+x*0.5329522; b[5]=-0.7616*b[5]-x*0.0168980
            out[i]=(b[0]+b[1]+b[2]+b[3]+b[4]+b[5]+b[6]+x*0.5362)*0.11
            b[6]=x*0.115926
        self._pb=b; return out
    def generate(self,frames):
        sig=self._pink(np.random.randn(frames))*0.9
        pos=self._dpos
        for n in range(frames):
            if pos>=len(self._dbuf):
                self._dtimer+=1
                ivl=int(random.uniform(0.05,0.35)*SR)
                if self._dtimer%max(1,ivl//BLOCK)==0:
                    amp=random.uniform(0.15,0.5); dur=random.randint(80,300)
                    env=np.exp(-np.arange(dur)/(dur*0.15))
                    self._dbuf=amp*env*np.random.randn(dur); pos=0
            if pos<len(self._dbuf): sig[n]+=self._dbuf[pos]; pos+=1
        self._dpos=pos; return sig

class WindLayer(Layer):
    def __init__(self):
        super().__init__("Wind",(0.5,0.85,0.6)); self._br=0.0; self._lp=0.0; self.volume=0.4
    def generate(self,frames):
        w=np.random.randn(frames); out=np.empty(frames); s=self._br
        for i,x in enumerate(w): s=(s+0.02*x)/1.02; out[i]=s
        self._br=s
        t=self._t+np.arange(frames,dtype=np.float64)
        lfo=(0.5+0.5*np.sin(TWO_PI*0.04*t/SR))*(0.5+0.5*np.sin(TWO_PI*0.11*t/SR+1.3))
        mod=0.3+0.7*lfo
        lp=self._lp
        for i in range(frames): lp=lp*0.998+out[i]*0.002; out[i]=lp
        self._lp=lp
        out*=mod; peak=np.max(np.abs(out))+1e-9; return out/peak*0.6

class PulseLayer(Layer):
    def __init__(self):
        super().__init__("Pulse",(1.0,0.65,0.5)); self.volume=0.4
    def generate(self,frames):
        t=self._t+np.arange(frames,dtype=np.float64)
        env=(np.sin(TWO_PI*0.22*t/SR)*0.5+0.5)**4; f=82.41
        sig=env*(np.sin(TWO_PI*f*t/SR)+0.4*np.sin(TWO_PI*f*1.5*t/SR)+0.2*np.sin(TWO_PI*f*2*t/SR))
        return sig*0.7

class BellLayer(Layer):
    NOTES=[261.63,293.66,329.63,392.0,440.0,523.25,587.33,659.25]
    def __init__(self):
        super().__init__("Bells",(1.0,0.9,0.55))
        self._next=int(random.uniform(2,6)*SR); self._events=[]; self.volume=0.35
    def _tone(self,freq,amp,dur_s):
        t=np.arange(int(dur_s*SR),dtype=np.float64)
        env=np.exp(-t/(dur_s*SR*0.18))
        return amp*env*(np.sin(TWO_PI*freq*t/SR)+0.35*np.sin(TWO_PI*freq*2.76*t/SR)+0.12*np.sin(TWO_PI*freq*5.4*t/SR))
    def generate(self,frames):
        sig=np.zeros(frames)
        if self._t>=self._next:
            tone=self._tone(random.choice(self.NOTES),random.uniform(0.3,0.7),random.uniform(1.8,4.0))
            self._events.append([self._t,tone])
            self._next=self._t+int(random.uniform(3,10)*SR)
        alive=[]
        for ev in self._events:
            st,tone=ev; off=self._t-st
            if off>=len(tone): continue
            av=min(frames,len(tone)-off); sig[:av]+=tone[off:off+av]; alive.append(ev)
        self._events=alive; return sig

class NoiseLayer(Layer):
    def __init__(self):
        super().__init__("Noise",(0.65,0.65,0.7)); self._pb=np.zeros(7); self._br=0.0; self.volume=0.3
    def _pink(self,w):
        b=self._pb; out=np.empty_like(w)
        for i,x in enumerate(w):
            b[0]=0.99886*b[0]+x*0.0555179; b[1]=0.99332*b[1]+x*0.0750759
            b[2]=0.96900*b[2]+x*0.1538520; b[3]=0.86650*b[3]+x*0.3104856
            b[4]=0.55000*b[4]+x*0.5329522; b[5]=-0.7616*b[5]-x*0.0168980
            out[i]=(b[0]+b[1]+b[2]+b[3]+b[4]+b[5]+b[6]+x*0.5362)*0.11
            b[6]=x*0.115926
        self._pb=b; return out
    def generate(self,frames):
        w=np.random.randn(frames); p=self._pink(w.copy())
        out=np.empty(frames); s=self._br
        for i,x in enumerate(w): s=(s+0.02*x)/1.02; out[i]=s
        self._br=s; brown=out/(np.max(np.abs(out))+1e-9)*0.5
        return w*0.15+p*0.5+brown*0.35

# ── Engine ────────────────────────────────────────────────────────────────────

class AudioEngine:
    def __init__(self):
        self.layers=[DroneLayer(),ShimmerLayer(),RainLayer(),WindLayer(),PulseLayer(),BellLayer(),NoiseLayer()]
        self.master_vol=0.5; self.reverb=SimpleReverb()
        self._playing=False; self._stream=None; self._lock=threading.Lock()
    def set_master(self,v): self.master_vol=max(0.0,min(1.0,v))
    def set_reverb(self,v): self.reverb.set_wet(v)
    def start(self):
        if self._playing: return
        self._playing=True
        self._stream=sd.OutputStream(samplerate=SR,channels=2,blocksize=BLOCK,dtype='float32',callback=self._cb)
        self._stream.start()
    def stop(self):
        self._playing=False
        if self._stream: self._stream.stop(); self._stream.close(); self._stream=None
    def _cb(self,outdata,frames,t,s):
        mix=np.zeros(frames,dtype=np.float64)
        with self._lock:
            for l in self.layers: mix+=l.tick(frames)
        mix=self.reverb.process(mix)*self.master_vol
        mix=np.tanh(mix*1.1)/1.1
        sp=7; right=np.concatenate([mix[sp:],mix[:sp]])
        outdata[:,0]=mix.astype(np.float32); outdata[:,1]=right.astype(np.float32)

