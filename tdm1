#  AUDIO ENGINE
# ─────────────────────────────────────────────

SAMPLE_RATE = 44100
BLOCK_SIZE  = 2048

class AudioEngine:
    """Generates ambient sound in real time using numpy."""

    MOODS = {
        "Focus": {
            "desc": "steady warmth, no distractions",
            "base_freq": 55.0,       # A1 — deep, grounding
            "harmonics": [1, 2, 3],
            "harmonic_amps": [1.0, 0.4, 0.15],
            "noise_color": "brown",
            "noise_level": 0.04,
            "pulse": False,
            "shimmer": False,
        },
        "Dreamy": {
            "desc": "soft pads, evolving shimmer",
            "base_freq": 146.83,     # D3 — airy, luminous
            "harmonics": [1, 1.5, 2, 3, 4],
            "harmonic_amps": [1.0, 0.6, 0.35, 0.2, 0.08],
            "noise_color": "pink",
            "noise_level": 0.02,
            "pulse": False,
            "shimmer": True,
        },
        "Rain": {
            "desc": "textured noise, gentle pulse",
            "base_freq": 82.41,      # E2 — warm low hum
            "harmonics": [1, 2],
            "harmonic_amps": [1.0, 0.3],
            "noise_color": "white",
            "noise_level": 0.18,
            "pulse": True,
            "shimmer": False,
        },
    }

    def __init__(self):
        self.mood       = "Focus"
        self.volume     = 0.35
        self.intensity  = 0.5       # 0..1 — affects harmonic richness & noise
        self._playing   = False
        self._lock      = threading.Lock()
        self._phase     = 0.0
        self._t         = 0          # sample counter
        self._fade_in   = 0.0        # 0→1 smooth transition
        self._target_mood = "Focus"
        self._crossfade  = 1.0       # 1.0 = fully settled

        # Brown/pink noise state
        self._brown_state = 0.0
        self._pink_b = np.zeros(7)

        self._stream = None

    # ── public API ──────────────────────────────

    def set_mood(self, mood):
        with self._lock:
            self._target_mood = mood
            self._crossfade   = 0.0  # triggers fade

    def set_volume(self, v):   self.volume    = max(0.0, min(1.0, v))
    def set_intensity(self, v): self.intensity = max(0.0, min(1.0, v))

    def start(self):
        if self._playing:
            return
        self._playing = True
        self._fade_in = 0.0
        self._stream = sd.OutputStream(
            samplerate=SAMPLE_RATE,
            channels=2,
            blocksize=BLOCK_SIZE,
            dtype='float32',
            callback=self._callback,
        )
        self._stream.start()

    def stop(self):
        self._playing = False
        if self._stream:
            self._stream.stop()
            self._stream.close()
            self._stream = None

    # ── internal synthesis ───────────────────────

    def _callback(self, outdata, frames, time_info, status):
        with self._lock:
            mood_cfg  = self.MOODS[self.mood]
            t_cfg     = self.MOODS[self._target_mood]

        t = np.arange(frames) + self._t
        self._t += frames

        # Smooth fade-in on first start
        if self._fade_in < 1.0:
            self._fade_in = min(1.0, self._fade_in + frames / (SAMPLE_RATE * 1.5))

        # Crossfade between moods
        if self._crossfade < 1.0:
            self._crossfade = min(1.0, self._crossfade + frames / (SAMPLE_RATE * 2.0))
            if self._crossfade >= 1.0:
                with self._lock:
                    self.mood = self._target_mood
                    mood_cfg  = self.MOODS[self.mood]

        blend = self._crossfade  # 0=old mood, 1=new mood

        sig_old = self._synthesize(t, mood_cfg, frames)
        sig_new = self._synthesize(t, t_cfg,    frames)
        signal  = sig_old * (1 - blend) + sig_new * blend

        # Master volume + fade-in envelope
        signal *= self.volume * self._fade_in

        # Stereo: slight spread
        left  = signal * 0.95
        right = signal * 1.05
        outdata[:, 0] = left.astype(np.float32)
        outdata[:, 1] = right.astype(np.float32)

    def _synthesize(self, t, cfg, frames):
        sr  = SAMPLE_RATE
        sig = np.zeros(frames)
        freq = cfg["base_freq"]

        # ── Harmonics (drone / pad) ──────────────
        for h, amp in zip(cfg["harmonics"], cfg["harmonic_amps"]):
            # Very slow LFO per harmonic for organic feel
            lfo_rate = 0.07 + h * 0.03
            lfo = 1.0 + 0.06 * np.sin(2 * np.pi * lfo_rate * t / sr)
            sig += amp * lfo * np.sin(2 * np.pi * freq * h * t / sr)

        # Normalise harmonics portion
        sig /= (sum(cfg["harmonic_amps"]) + 1e-9)
        sig *= (0.6 + 0.4 * self.intensity)

        # ── Shimmer (Dreamy mode) ────────────────
        if cfg["shimmer"]:
            shimmer_freq = freq * 8
            depth = 0.18 * self.intensity
            lfo_s = np.sin(2 * np.pi * 0.3 * t / sr)
            sig  += depth * lfo_s * np.sin(2 * np.pi * shimmer_freq * t / sr)

        # ── Pulse (Rain mode) ────────────────────
        if cfg["pulse"]:
            pulse_rate = 0.5  # Hz
            pulse = (np.sin(2 * np.pi * pulse_rate * t / sr) * 0.5 + 0.5) ** 3
            sig  += 0.15 * self.intensity * pulse * np.sin(2 * np.pi * freq * 1.5 * t / sr)

        # ── Noise layer ──────────────────────────
        noise_raw = np.random.randn(frames).astype(np.float64)

        if cfg["noise_color"] == "brown":
            noise = self._brown_noise(noise_raw)
        elif cfg["noise_color"] == "pink":
            noise = self._pink_noise(noise_raw)
        else:
            noise = noise_raw * 0.3

        noise_level = cfg["noise_level"] * (0.5 + 0.5 * self.intensity)
        sig += noise_level * noise

        return sig

    def _brown_noise(self, white):
        out = np.empty_like(white)
        s   = self._brown_state
        for i, w in enumerate(white):
            s = (s + 0.02 * w) / 1.02
            out[i] = s
        self._brown_state = s
        peak = np.max(np.abs(out)) + 1e-9
        return out / peak * 0.5

    def _pink_noise(self, white):
        b = self._pink_b
        out = np.empty_like(white)
        for i, w in enumerate(white):
            b[0] = 0.99886*b[0] + w*0.0555179
            b[1] = 0.99332*b[1] + w*0.0750759
            b[2] = 0.96900*b[2] + w*0.1538520
            b[3] = 0.86650*b[3] + w*0.3104856
            b[4] = 0.55000*b[4] + w*0.5329522
            b[5] = -0.7616*b[5] - w*0.0168980
            out[i] = (b[0]+b[1]+b[2]+b[3]+b[4]+b[5] + b[6] + w*0.5362) * 0.11
            b[6] = w * 0.115926
        self._pink_b = b
        return out


