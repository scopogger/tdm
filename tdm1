for line in raw_lines:
    parsed = parse_chunk(line)
    if parsed is None:
        print(f"  ! Skipping unrecognized line: {line[:60]!r}")
        continue
    idx, total, payload = parsed
    if total_expected is None:
        total_expected = total
    elif total != total_expected:
        print(f"  ! Warning: inconsistent total ({total} vs {total_expected})")
    chunks[idx] = payload

if total_expected is None:
    raise ValueError("No valid chunks found!")

missing = [i for i in range(1, total_expected + 1) if i not in chunks]
if missing:
    raise ValueError(
        f"Missing chunks: {missing}\n"
        f"Got {len(chunks)}/{total_expected}. Scan those QR codes and try again."
    )

full_b64 = ''.join(chunks[i] for i in range(1, total_expected + 1))
full_json = base64.b64decode(full_b64).decode('utf-8')
return full_json
