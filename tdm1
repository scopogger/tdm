def write_files(json_str: str, out_dir: str):
entries = json.loads(json_str)
os.makedirs(out_dir, exist_ok=True)
print(f”\nWriting {len(entries)} file(s) to ./{out_dir}/\n”)
for entry in entries:
rel_path = entry[‘p’]
data     = base64.b64decode(entry[‘d’])
dest     = os.path.join(out_dir, rel_path)
os.makedirs(os.path.dirname(dest) or ‘.’, exist_ok=True)
with open(dest, ‘wb’) as f:
f.write(data)
print(f”  ✓  {rel_path}  ({len(data)} bytes)”)
print(f”\nDone! Files saved to: {os.path.abspath(out_dir)}”)

