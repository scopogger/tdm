# ─────────────────────────────────────────────

class VisualizerWidget(QWidget):
    """Soft pulsing orb that reacts to mood."""

    MOOD_COLORS = {
        "Focus":  [(0.6, 0.85, 1.0),  (0.3, 0.55, 0.9)],   # cool blue
        "Dreamy": [(0.85, 0.65, 1.0), (0.55, 0.3,  0.9)],  # lavender
        "Rain":   [(0.5, 0.85, 0.75), (0.2, 0.6,  0.55)],  # teal-green
    }

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setMinimumSize(220, 220)
        self._mood    = "Focus"
        self._phase   = 0.0
        self._playing = False

        self._timer = QTimer()
        self._timer.timeout.connect(self._tick)
        self._timer.start(33)  # ~30fps

    def set_mood(self, mood):
        self._mood = mood
        self.update()

    def set_playing(self, playing):
        self._playing = playing

    def _tick(self):
        if self._playing:
            self._phase += 0.025
        self.update()

    def paintEvent(self, event):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)

        w, h   = self.width(), self.height()
        cx, cy = w / 2, h / 2
        r_base = min(w, h) * 0.33

        colors = self.MOOD_COLORS[self._mood]
        c1 = QColor.fromRgbF(*colors[0], 0.85)
        c2 = QColor.fromRgbF(*colors[1], 0.4)

        # Outer glow rings (slow pulse)
        for i in range(3):
            pulse = math.sin(self._phase + i * 0.8) * 0.5 + 0.5
            r = r_base * (1.05 + i * 0.18 + pulse * 0.12)
            alpha = 0.12 - i * 0.035
            glow = QColor.fromRgbF(*colors[1], alpha)
            p.setBrush(QBrush(glow))
            p.setPen(Qt.NoPen)
            p.drawEllipse(int(cx - r), int(cy - r), int(r * 2), int(r * 2))

        # Core orb — radial gradient
        pulse_core = math.sin(self._phase * 1.1) * 0.5 + 0.5
        r_core = r_base * (0.85 + pulse_core * 0.1)

        grad = QRadialGradient(cx, cy, r_core)
        grad.setColorAt(0.0, QColor.fromRgbF(*colors[0], 0.95))
        grad.setColorAt(0.5, QColor.fromRgbF(*colors[1], 0.75))
        grad.setColorAt(1.0, QColor.fromRgbF(*colors[1], 0.0))
        p.setBrush(QBrush(grad))
        p.setPen(Qt.NoPen)
        p.drawEllipse(int(cx - r_core), int(cy - r_core), int(r_core * 2), int(r_core * 2))

        # Inner bright spot
        r_spot = r_base * 0.28
        spot = QRadialGradient(cx - r_base*0.12, cy - r_base*0.12, r_spot)
        spot.setColorAt(0.0, QColor.fromRgbF(1, 1, 1, 0.55))
        spot.setColorAt(1.0, QColor.fromRgbF(1, 1, 1, 0.0))
        p.setBrush(QBrush(spot))
        p.drawEllipse(int(cx - r_spot*1.3), int(cy - r_spot*1.3), int(r_spot*2.6), int(r_spot*2.6))

        p.end()


